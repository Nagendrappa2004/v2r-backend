PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/homeStore
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─── Email (Gmail) — customer + admin order confirmation ───
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
# Optional: separate inbox for new-order alerts (defaults to GMAIL_USER)
ADMIN_ORDER_EMAIL=info@v2rheritages.com

# ─── Razorpay ───
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-secret

# ─── WhatsApp auto messages after order (set provider when API is ready) ───
# WHATSAPP_PROVIDER=none | meta | twilio | custom
WHATSAPP_PROVIDER=none

# Meta WhatsApp Cloud API (developers.facebook.com)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Custom provider — POST { to, message } to your API URL
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Store / seller WhatsApp (91XXXXXXXXXX) — receives new-order alert
WHATSAPP_ADMIN_NUMBER=918088411798
WHATSAPP_SELLER_NUMBER=918088411798
# Set to false to only message customer, not admin
WHATSAPP_NOTIFY_ADMIN=true

# ─── Google Sheet product sync ───
GOOGLE_SHEET_API_KEY=
GOOGLE_SHEET_ID=
